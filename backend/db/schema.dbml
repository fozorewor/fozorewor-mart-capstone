Table users {
  id int [pk, increment]
  username text [not null, unique]
  email text [not null, unique]
  password text [not null]
  created_at timestamp [not null]
}

Table categories {
  id int [pk, increment]
  slug text [not null, unique]
  name text [not null, unique]
  description text
}

Table products {
  id int [pk, increment]
  slug text [not null, unique]
  category_id int [not null, ref: > categories.id]
  name text [not null]
  description text
  keywords text [note: 'Stored as a Postgres text[] in schema.sql']
  price_cents int [not null]
  stock_quantity int [not null]
  is_active boolean [not null]
  rating_stars decimal(2,1) [not null]
  rating_count int [not null]
  unit_label text
  image_path text
  image_gallery_paths text [note: 'Stored as a Postgres text[] in schema.sql']
  created_at timestamp [not null]
}
