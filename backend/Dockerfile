FROM node:22-alpine AS frontend-builder

WORKDIR /app/frontend

ARG VITE_API
ARG VITE_NEW_RELIC_ENABLED
ARG VITE_NEW_RELIC_ACCOUNT_ID
ARG VITE_NEW_RELIC_TRUST_KEY
ARG VITE_NEW_RELIC_AGENT_ID
ARG VITE_NEW_RELIC_APPLICATION_ID
ARG VITE_NEW_RELIC_BROWSER_LICENSE_KEY
ARG VITE_NEW_RELIC_BEACON
ARG VITE_NEW_RELIC_ERROR_BEACON
ARG VITE_NEW_RELIC_LOADER_URL

ENV VITE_API=$VITE_API
ENV VITE_NEW_RELIC_ENABLED=$VITE_NEW_RELIC_ENABLED
ENV VITE_NEW_RELIC_ACCOUNT_ID=$VITE_NEW_RELIC_ACCOUNT_ID
ENV VITE_NEW_RELIC_TRUST_KEY=$VITE_NEW_RELIC_TRUST_KEY
ENV VITE_NEW_RELIC_AGENT_ID=$VITE_NEW_RELIC_AGENT_ID
ENV VITE_NEW_RELIC_APPLICATION_ID=$VITE_NEW_RELIC_APPLICATION_ID
ENV VITE_NEW_RELIC_BROWSER_LICENSE_KEY=$VITE_NEW_RELIC_BROWSER_LICENSE_KEY
ENV VITE_NEW_RELIC_BEACON=$VITE_NEW_RELIC_BEACON
ENV VITE_NEW_RELIC_ERROR_BEACON=$VITE_NEW_RELIC_ERROR_BEACON
ENV VITE_NEW_RELIC_LOADER_URL=$VITE_NEW_RELIC_LOADER_URL

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./
RUN npm run build

FROM node:22-alpine

WORKDIR /app/backend

COPY backend/package*.json ./
RUN npm ci --omit=dev

COPY backend/ ./
COPY --from=frontend-builder /app/frontend/dist /app/frontend/dist
COPY --from=frontend-builder /app/frontend/images /app/frontend/images

EXPOSE 3005

CMD ["node", "server.js"]
